{
          "name": "scp-os",
          "private": true,
          "version": "0.5.0",
          "type": "module",
          "description": "SCP Foundation Web OS - Monorepo",
          "scripts": {
                    "dev": "pnpm --filter @scp-os/app dev",
                    "dev:development": "pnpm --filter @scp-os/app dev:development",
                    "dev:production": "pnpm --filter @scp-os/app dev:production",
                    "build": "pnpm --filter @scp-os/app build",
                    "build:development": "pnpm --filter @scp-os/app build:development",
                    "build:production": "pnpm --filter @scp-os/app build:production",
                    "preview": "pnpm --filter @scp-os/app preview",
                    "test": "pnpm --filter @scp-os/app test && pnpm --filter scp-os-worker test",
                    "test:ui": "pnpm --filter @scp-os/app test:ui",
                    "test:coverage": "pnpm --filter @scp-os/app test:coverage && pnpm --filter scp-os-worker test:coverage",
                    "worker:dev": "pnpm --filter scp-os-worker dev",
                    "worker:build": "pnpm --filter scp-os-worker build",
                    "worker:deploy": "pnpm --filter scp-os-worker deploy",
                    "worker:tail": "pnpm --filter scp-os-worker tail",
                    "desktop:dev": "pnpm --filter @scp-os/desktop tauri:dev",
                    "desktop:build": "pnpm --filter @scp-os/desktop tauri:build",
                    "typecheck": "pnpm --filter @scp-os/app typecheck && pnpm --filter scp-os-worker run typecheck",
                    "lint:check": "pnpm --filter @scp-os/app lint:check",
                    "lint": "eslint . --ext .ts,.vue",
                    "format": "prettier --write ."
          },
          "devDependencies": {
                    "@cloudflare/workers-types": "^4.20260411.1",
                    "typescript": "~5.9.3"
          },
          "engines": {
                    "node": ">=18.0.0",
                    "pnpm": ">=8.0.0"
          },
          "packageManager": "pnpm@10.3.0",
          "pnpm": {
                    "onlyBuiltDependencies": [
                              "esbuild",
                              "sharp",
                              "workerd"
                    ],
                    "overrides": {
                              "@xmldom/xmldom": "0.8.13",
                              "postcss": "8.5.10",
                              "js-cookie": "3.0.7",
                              "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
                              "ws@>=8.0.0 <8.20.1": "8.20.1"
                    }
          }
}
