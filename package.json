{
  "name": "scp-foundation-terminal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:development": "vite --mode development",
    "dev:production": "vite --mode production",
    "build": "vue-tsc -b && vite build",
    "build:development": "vue-tsc -b && vite build --mode development",
    "build:production": "vue-tsc -b && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "vue-tsc --noEmit",
    "format": "echo 'No formatter configured'",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@pinia/testing": "^1.0.3",
    "@tauri-apps/api": "^2.10.1",
    "axios": "^1.14.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^24.12.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
